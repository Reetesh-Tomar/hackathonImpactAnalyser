# ============================================================
# AI Change Impact Analyzer — AI service configuration
#
# Currently running on a LOCAL LLM via Ollama (no API key, fully
# offline, zero cost) — installed and pulled automatically:
#   model: llama3.2:3b   server: http://localhost:11434
#
# Want a bigger/faster hosted model instead? Get a free key from
# https://console.groq.com/keys, paste it into GROQ_API_KEY below,
# and change AI_PROVIDER to: groq
# ============================================================

# Controls ONLY the conversational /chat and /assistant endpoints.

#AI_PROVIDER=ollama

# Controls the deterministic multi-agent risk-analysis pipeline
# (/api/v1/change-impact/analyze and /api/v2/.../analyze-react).
# Deliberately kept separate from AI_PROVIDER and defaulted to "mock":
# the pipeline runs 7 agents per request, and pointing all 7 at a live
# LLM serially made a single "Analyze" click take 30-120+ seconds and
# time out. Leave this as "mock" for a fast, deterministic, reliable
# demo. Only set it to ollama/groq/openai/openrouter if you specifically
# want live-LLM-generated narrative text inside the pipeline and are
# fine with a much slower analysis (and have raised ai-service.timeout
# in backend/src/main/resources/application*.yml accordingly).

#PIPELINE_AI_PROVIDER=mock

# --- Groq (free tier, fast llama models) ---

#GROQ_API_KEY=
#GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI ---

#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini

# --- OpenRouter ---
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=anthropic/claude-3-haiku

# --- Ollama (local model, no key needed) ---
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.2:3b





# Chat endpoints
AI_PROVIDER=groq

# Pipeline endpoints
PIPELINE_AI_PROVIDER=groq

# Groq
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

# Optional (unchanged)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
